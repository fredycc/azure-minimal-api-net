# Environment Variables — Example
# ================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Most variables are optional — deploy.ps1 prompts interactively if not set.

# Pulumi config encryption passphrase (optional — script prompts if not set)
# PULUMI_CONFIG_PASSPHRASE=your-passphrase

# Azure subscription ID (optional — defaults to `az account show`)
# AZURE_SUBSCRIPTION_ID=